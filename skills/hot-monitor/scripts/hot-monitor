"""
Hot Monitor — 零依赖热点采集 CLI
用法: python hot-monitor <command> [options]
      ./hot-monitor <command> [options]    (Unix chmod +x)
"""

import sys
import os

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
